{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "rootDir": "./src",
    "types": ["node"],
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts"]
}
