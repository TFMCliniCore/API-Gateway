          }
        },
        {
          "name": "Subir foto de perfil",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "foto",
                  "type": "file",
                  "src": "",
                  "description": "JPG, PNG o WebP. Max 3 MB."
                }
              ]
            },
            "url": "{{baseUrl}}/usuarios/1/foto",
            "description": "No incluir Content-Type manualmente. Devuelve usuario actualizado con nueva ruta de foto."
          }
        },
        {
          "name": "Obtener foto de perfil",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/usuarios/foto/usuario_1_1748970000000.jpg",
            "description": "No requiere auth. Reemplazar el nombre de archivo."
          }
        },
        {
          "name": "Eliminar usuario",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/usuarios/1"
          }
        }
      ]
