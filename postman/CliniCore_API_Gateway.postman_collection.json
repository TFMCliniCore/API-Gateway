{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "CliniCore API Gateway",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion Postman para el API Gateway de CliniCore (puerto 3002). Flujo: 1) Login, 2) Copiar access_token, 3) Pegarlo en la variable \"token\" de la coleccion. El resto de peticiones usan ese token automaticamente."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3002/api/v1",
      "description": "URL base del API Gateway en desarrollo local"
    },
    {
      "key": "token",
      "value": "",
      "description": "Token JWT. Pegar el access_token aqui tras el login."
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@clinicavet.test\",\n  \"password\": \"Admin2026!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Autentica y devuelve access_token (vigencia 15 min) + objeto usuario completo. Payload JWT: sub (id), email, nombres, rolId, sucursalId. Guardar access_token en la variable \"token\"."
          }
        },
        {
          "name": "Auth Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/status",
            "description": "Estado del modulo JWT/Passport."
          }
        }
      ]
    },
    {
      "name": "Gateway",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Servicios registrados",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/gateway/services"
          }
        },
        {
          "name": "Rutas registradas",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/gateway/routes"
          }
        }
      ]
    },
    {
