              "raw": "{\n  \"nombres\": \"Juliana Torres\",\n  \"email\": \"juliana.torres@clinicavet.test\",\n  \"celular\": \"3005557788\",\n  \"cargo\": \"Veterinaria\",\n  \"contrasena\": \"ClaveTemporal2026\",\n  \"sucursalId\": 1,\n  \"rolId\": 2\n}"
