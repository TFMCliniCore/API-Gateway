              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombres\": \"Juliana Torres Mejia\",\n  \"celular\": \"3005557799\",\n  \"cargo\": \"Veterinario\",\n  \"rolId\": 2\n}"
            },
            "url": "{{baseUrl}}/usuarios/1"
          }
        },
        {
          "name": "Cambiar contrasena",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
