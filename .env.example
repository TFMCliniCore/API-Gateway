# ... (campos existentes)
MS_ENTIDADES_CORE_URL=
MS_REPORTES_URL=http://host.docker.internal:3006/api/v1
MS_INTEGRACIONES_URL=http://host.docker.internal:3009/api/v1
CORS_ORIGIN="*"

# --- Configuración de Correo (Nodemailer / Mailtrap) ---
# El host suele ser sandbox.smtp.mailtrap.io para pruebas
MAIL_HOST=
# El puerto estándar de Mailtrap es 2525 o 587
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
# Dirección que aparecerá como remitente (ej: "ClinicaVet <no-reply@clinicavet.test>")
MAIL_FROM=

# --- Configuración de Microservicios ---
# URL base para el microservicio de entidades (donde se gestionan usuarios y roles)
MS_ENTIDADES_URL=